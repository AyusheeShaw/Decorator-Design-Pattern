
public class Main {
    public static void main(String[] args) {
        System.out.println("Hello World!");
        Pizza p=new Paneer(new Cheese(new Tomato(new BBQChicken())));
        System.out.println(p.getPrice());
        System.out.println(p.getDescription());
        
    }
}
interface Pizza{
    public int getPrice();
    public String getDescription();
}
class Farmhouse implements Pizza{
    Pizza pizza;
    
    public Farmhouse(){}
    public Farmhouse(Pizza pizza){
        this.pizza=pizza;
    }
    public int getPrice(){
        if(pizza!=null){
            return pizza.getPrice()+150;
        }
        return 150; 
    }
    public String getDescription(){
        if(pizza!=null){
            return pizza.getDescription()+" "+"Farmhouse";
        }
        return "Farmhouse";
    }
}
